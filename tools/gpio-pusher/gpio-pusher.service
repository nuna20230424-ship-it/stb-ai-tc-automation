[Unit]
Description=GPIO Pusher Service (STB BT Pairing Automation)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/gpio-pusher
ExecStart=/opt/gpio-pusher/.venv/bin/uvicorn pusher_service:app --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
