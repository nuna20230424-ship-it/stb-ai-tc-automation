# tests/.env (복사: cp .env.example .env)

# ── Notebook Gateway (운영자 노트북) ──────────────────────────
GATEWAY_BASE_URL=http://localhost:8080
# 또는 각 서비스 직접 호출:
CAPTURE_MCP_URL=http://localhost:8001
IR_MCP_URL=http://localhost:8002
UART_MCP_URL=http://localhost:8003
POWER_MCP_URL=http://localhost:8004
VOICE_MCP_URL=http://localhost:8005
BLUETOOTH_MCP_URL=http://localhost:8006

# ── Mac mini Backend (사내 랙) ────────────────────────────────
BACKEND_BASE_URL=http://10.0.10.50:8100
BASELINE_MCP_URL=http://10.0.10.50:8101
EMBEDDING_MCP_URL=http://10.0.10.50:8102
DETECTION_MCP_URL=http://10.0.10.50:8103
REPORT_MCP_URL=http://10.0.10.50:8104

# ── InfluxDB (메트릭) ────────────────────────────────────────
INFLUX_URL=http://10.0.10.50:8086
INFLUX_TOKEN=change-me-token-32chars-min
INFLUX_ORG=stbqa
INFLUX_BUCKET=stb-metrics

# ── 시나리오 파라미터 ─────────────────────────────────────────
IR_CODESET=ref_remote
BOOT_WAIT_SEC=30
ZAP_WAIT_SEC=3
CAPTURE_DURATION_SEC=2
SIMILARITY_THRESHOLD=0.92
JIRA_SEVERITY_DEFAULT=P2

# ── Sprint 2 Preconditions ────────────────────────────────────
# IR/voice 매크로 파라미터
LIVE_TV_KEY=LIVE
LIVE_TV_CHANNEL=default
PLAYBACK_WARMUP_SEC=6
PLAYBACK_SOURCE=vod_test_clip
VOD_TEST_VOICE=테스트 클립 재생
DRM_TEST_VOICE=넷플릭스에서 4K 콘텐츠 재생

# OTT 앱 로그인 (없으면 해당 시나리오 skip)
NETFLIX_EMAIL=
NETFLIX_PASSWORD=
NETFLIX_PROFILE=QA
NETFLIX_SKIP_LOGIN_IF_SESSION=true

TVING_ID=
TVING_PASSWORD=
TVING_PROFILE=QA
TVING_SKIP_LOGIN_IF_SESSION=true

# HDCP 미지원 디스플레이가 라인에 물려있을 때만 true
HDCP_UNSUPPORTED_PRESENT=false

# ── Sprint 2 카탈로그 확장 (Search/Recording/Parental/Settings) ─
SEARCH_KEY=SEARCH
SETTINGS_KEY=SETTINGS
RECORDING_OPEN_VOICE=녹화 목록
# Parental PIN (테스트 환경 기본값. 실 사용 시 .env에만 보관)
PARENTAL_PIN=0000
