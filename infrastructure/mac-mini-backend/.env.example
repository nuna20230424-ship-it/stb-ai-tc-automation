# Mac mini Backend 환경 변수 (복사: cp .env.example .env)

# ── Qdrant ────────────────────────────────────────────────────
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=change-me-qdrant-key

# ── InfluxDB ──────────────────────────────────────────────────
INFLUXDB_PORT=8086
INFLUX_USER=stbqa
INFLUX_PASSWORD=change-me-strong
INFLUX_TOKEN=change-me-token-32chars-min

# ── MinIO ─────────────────────────────────────────────────────
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USER=stbqa
MINIO_PASSWORD=change-me-strong

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_PASSWORD=change-me-strong

# ── MCP Services ──────────────────────────────────────────────
BASELINE_MCP_PORT=8101
EMBEDDING_MCP_PORT=8102
DETECTION_MCP_PORT=8103
REPORT_MCP_PORT=8104
BACKEND_PORT=8100

# ── Ollama (호스트 네이티브 실행) ──────────────────────────────
# Mac에서 `brew install ollama && ollama serve` 후
# `ollama pull nomic-embed-text` 및 `ollama pull llava:latest`
EMBEDDING_MODEL=nomic-embed-text
VISION_MODEL=llava:latest

# ── Detection 임계치 ──────────────────────────────────────────
SIMILARITY_THRESHOLD=0.92

# ── JIRA ──────────────────────────────────────────────────────
JIRA_URL=https://kaongroup.atlassian.net
JIRA_USER=keonhee.cho@kaongroup.com
JIRA_TOKEN=change-me-jira-api-token
JIRA_PROJECT=STBQA
