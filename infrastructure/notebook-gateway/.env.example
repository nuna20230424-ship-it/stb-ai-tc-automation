# Notebook Gateway 환경 변수 (복사: cp .env.example .env)

# ── Capture (HDMI) ────────────────────────────────────────────
# Linux: /dev/video0, /dev/video2 등 (ls /dev/video*)
# macOS: AVFoundation 인덱스 (예: "0", "1") — 단, macOS는 host-native 실행 권장
REF_CAPTURE_DEVICE=/dev/video0
DUT_CAPTURE_DEVICE=/dev/video2
CAPTURE_MCP_PORT=8001

# ── IR (어댑터 선택: itach | broadlink | itach-ilearner | adb | rdk) ──
IR_BACKEND=itach
# iTach IP2IR (송신 기본). 학습은 itach-ilearner로.
ITACH_HOST=10.0.10.20
ITACH_PORT=4998
# BroadLink RM4 Mini (송신+학습, 저가 대안)
BROADLINK_HOST=192.168.1.50
# ADB (Android TV STB 0원 자동화)
# 네트워크 ADB: "192.168.1.100:5555", USB ADB: 시리얼 번호 "ABCD1234"
ADB_TARGET=
# RDK Thunder 폴백 (IR_BACKEND=rdk) — Comcast/Sky RDK 박스 API 제어
RDK_HOST=10.0.10.60
RDK_PORT=9998
RDK_TOKEN=
IR_MCP_PORT=8002

# ── UART (FTDI USB-Serial) ────────────────────────────────────
# Linux: /dev/ttyUSB0, macOS: /dev/cu.usbserial-XXXX
REF_UART_DEVICE=/dev/ttyUSB0
DUT_UART_DEVICE=/dev/ttyUSB1
UART_BAUD=115200
UART_MCP_PORT=8003

# ── Power (Shelly Smart Plug) ─────────────────────────────────
REF_PLUG_HOST=10.0.10.31
DUT_PLUG_HOST=10.0.10.32
POWER_MCP_PORT=8004

# ── Voice (TTS + 스피커) ──────────────────────────────────────
VOICE_MCP_PORT=8005
VOICE_RATE=175
VOICE_VOLUME=1.0
# Linux: aplay, macOS: afplay (호스트 네이티브 실행 시)
PLAYBACK_CMD=aplay

# ── Bluetooth ─────────────────────────────────────────────────
BLUETOOTH_MCP_PORT=8006
# GPIO Pusher (Sprint 2 BT 페어링 자동화). 비어있으면 수동 모드.
GPIO_PUSHER_URL=
# GPIO_PUSHER_URL=http://gpio-pusher.local:8080

# ── Gateway Proxy ─────────────────────────────────────────────
GATEWAY_PORT=8080

# ── Mac mini Backend 연동 ─────────────────────────────────────
BACKEND_MINIO_ENDPOINT=http://10.0.10.50:9000
BACKEND_MINIO_ACCESS_KEY=stbqa
BACKEND_MINIO_SECRET_KEY=changeme-strong-secret
BACKEND_BASELINE_URL=http://10.0.10.50:8101
BACKEND_DETECTION_URL=http://10.0.10.50:8103
